<div class="p-6 sm:p-8 max-w-2xl mx-auto">
  <div class="mb-6">
    <a href="/artists/<%= artist.id %>/songs" class="inline-flex items-center gap-1 text-sm text-blue-600 hover:text-blue-700 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Songs
    </a>
  </div>

  <div class="bg-white rounded-xl border border-gray-100 shadow-sm">
    <div class="px-6 py-4 border-b border-gray-100">
      <h1 class="text-lg font-semibold text-gray-900">Edit Song</h1>
    </div>

    <% if error %>
    <div class="mx-6 mt-4 px-4 py-3 bg-red-50 border border-red-200 rounded-lg">
      <p class="text-sm text-red-700"><%= error %></p>
    </div>
    <% end %>

    <form method="POST" action="/artists/<%= artist.id %>/songs/<%= song.id %>" class="p-6 space-y-5">
      <div>
        <label for="title" class="block text-sm font-medium text-gray-700 mb-1">Title <span class="text-red-500">*</span></label>
        <input type="text" name="title" id="title" required
          value="<%= song.title %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label for="album_name" class="block text-sm font-medium text-gray-700 mb-1">Album Name</label>
          <input type="text" name="album_name" id="album_name"
            value="<%= song.album_name %>"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
        </div>

        <div>
          <label for="genre" class="block text-sm font-medium text-gray-700 mb-1">Genre</label>
          <select name="genre" id="genre"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
            <option value="">Select genre</option>
            <% %w[Pop Rock Hip-Hop R&B Country Jazz Classical Electronic Reggae Blues Folk Metal Punk Soul Funk Latin Indie Alternative].each do |g| %>
            <option value="<%= g %>" <%= song.genre == g ? 'selected' : '' %>><%= g %></option>
            <% end %>
          </select>
        </div>
      </div>

      <div class="flex items-center justify-end gap-3 pt-2">
        <a href="/artists/<%= artist.id %>/songs" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">Cancel</a>
        <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors">Update Song</button>
      </div>
    </form>
  </div>

  <div class="mt-6 bg-white rounded-xl border border-red-100 shadow-sm p-6">
    <h2 class="text-sm font-semibold text-red-600 mb-2">Danger Zone</h2>
    <p class="text-sm text-gray-500 mb-4">Once you delete a song, there is no going back.</p>
    <form method="POST" action="/artists/<%= artist.id %>/songs/<%= song.id %>/delete" onsubmit="return confirm('Are you sure you want to delete this song?')">
      <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 transition-colors">Delete Song</button>
    </form>
  </div>
</div>
