<div class="p-6 sm:p-8 max-w-2xl mx-auto">
  <div class="mb-6">
    <a href="/artists" class="inline-flex items-center gap-1 text-sm text-blue-600 hover:text-blue-700 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Back to Artists
    </a>
  </div>

  <div class="bg-white rounded-xl border border-gray-100 shadow-sm">
    <div class="px-6 py-4 border-b border-gray-100">
      <h1 class="text-lg font-semibold text-gray-900">Edit Artist</h1>
    </div>

    <% if error %>
    <div class="mx-6 mt-4 px-4 py-3 bg-red-50 border border-red-200 rounded-lg">
      <p class="text-sm text-red-700"><%= error %></p>
    </div>
    <% end %>

    <form method="POST" action="/artists/<%= artist.id %>" class="p-6 space-y-5">
      <div>
        <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name <span class="text-red-500">*</span></label>
        <input type="text" name="name" id="name" required
          value="<%= artist.name %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label for="dob" class="block text-sm font-medium text-gray-700 mb-1">Date of Birth</label>
          <input type="date" name="dob" id="dob"
            value="<%= artist.dob %>"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
        </div>

        <div>
          <label for="gender" class="block text-sm font-medium text-gray-700 mb-1">Gender</label>
          <select name="gender" id="gender"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
            <option value="">Select gender</option>
            <option value="Male" <%= artist.gender == 'Male' ? 'selected' : '' %>>Male</option>
            <option value="Female" <%= artist.gender == 'Female' ? 'selected' : '' %>>Female</option>
            <option value="Other" <%= artist.gender == 'Other' ? 'selected' : '' %>>Other</option>
          </select>
        </div>
      </div>

      <div>
        <label for="address" class="block text-sm font-medium text-gray-700 mb-1">Address</label>
        <textarea name="address" id="address" rows="3"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"><%= artist.address %></textarea>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label for="first_release_year" class="block text-sm font-medium text-gray-700 mb-1">First Release Year</label>
          <input type="number" name="first_release_year" id="first_release_year"
            value="<%= artist.first_release_year %>"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
        </div>

        <div>
          <label for="no_of_albums_released" class="block text-sm font-medium text-gray-700 mb-1">No. of Albums Released</label>
          <input type="number" name="no_of_albums_released" id="no_of_albums_released" min="0"
            value="<%= artist.no_of_albums_released %>"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
        </div>
      </div>

      <div class="flex items-center justify-end gap-3 pt-2">
        <a href="/artists" class="px-4 py-2 text-sm font-medium text-gray-600 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">Cancel</a>
        <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors">Update Artist</button>
      </div>
    </form>
  </div>

  <div class="mt-6 bg-white rounded-xl border border-gray-100 shadow-sm p-6">
    <h2 class="text-sm font-semibold text-gray-900 mb-3">Link Artist to User</h2>

    <% if linked_user %>
    <div class="flex items-center justify-between mb-4 p-3 bg-emerald-50 rounded-lg">
      <div>
        <p class="text-sm font-medium text-emerald-800">Currently linked to:</p>
        <p class="text-sm text-emerald-700"><%= linked_user['first_name'] %> (ID: <%= linked_user['id'] %>)</p>
      </div>
      <form method="POST" action="/artists/<%= artist.id %>">
        <input type="hidden" name="name" value="<%= artist.name %>">
        <input type="hidden" name="dob" value="<%= artist.dob %>">
        <input type="hidden" name="gender" value="<%= artist.gender %>">
        <input type="hidden" name="address" value="<%= artist.address %>">
        <input type="hidden" name="first_release_year" value="<%= artist.first_release_year %>">
        <input type="hidden" name="no_of_albums_released" value="<%= artist.no_of_albums_released %>">
        <input type="hidden" name="link_action" value="unlink">
        <button type="submit" class="px-3 py-1.5 text-xs font-medium text-red-600 bg-red-50 rounded-lg hover:bg-red-100 transition-colors">
          Unlink
        </button>
      </form>
    </div>
    <% end %>

    <% if available_users && !available_users.empty? %>
    <form method="POST" action="/artists/<%= artist.id %>" class="flex items-end gap-3">
      <div class="flex-1">
        <label for="user_id" class="block text-sm font-medium text-gray-700 mb-1">Assign User</label>
        <select name="user_id" id="user_id"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent">
          <option value="">Select a user...</option>
          <% available_users.each do |u| %>
          <option value="<%= u['id'] %>"><%= u['first_name'] %> (ID: <%= u['id'] %>)</option>
          <% end %>
        </select>
      </div>
      <input type="hidden" name="name" value="<%= artist.name %>">
      <input type="hidden" name="dob" value="<%= artist.dob %>">
      <input type="hidden" name="gender" value="<%= artist.gender %>">
      <input type="hidden" name="address" value="<%= artist.address %>">
      <input type="hidden" name="first_release_year" value="<%= artist.first_release_year %>">
      <input type="hidden" name="no_of_albums_released" value="<%= artist.no_of_albums_released %>">
      <input type="hidden" name="link_action" value="link">
      <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-emerald-600 rounded-lg hover:bg-emerald-700 transition-colors whitespace-nowrap">
        Link User
      </button>
    </form>
    <% elsif !linked_user %>
    <p class="text-sm text-gray-500">No available artist-role users to link.</p>
    <% end %>
  </div>

  <div class="mt-6 bg-white rounded-xl border border-red-100 shadow-sm p-6">
    <h2 class="text-sm font-semibold text-red-600 mb-2">Danger Zone</h2>
    <p class="text-sm text-gray-500 mb-4">Once you delete an artist, there is no going back. All associated songs will also be deleted.</p>
    <form method="POST" action="/artists/<%= artist.id %>/delete" onsubmit="return confirm('Are you sure you want to delete this artist?')">
      <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 transition-colors">Delete Artist</button>
    </form>
  </div>
</div>
